# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE_BOOKS_API_KEY: Optional. Your Google Books API Key to avoid query rate limits when enriching book details.
# Configure this via the Secrets / Environment Variables panel in the Settings menu of the AI Studio UI.
GOOGLE_BOOKS_API_KEY=

# Firebase web app config. These are public client-side identifiers, not secret keys.
# In Vercel, add these for the Firebase project that owns Google sign-in.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=book-nerd.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=book-nerd
VITE_FIREBASE_STORAGE_BUCKET=book-nerd.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional. Leave blank to use the default Firestore database.
VITE_FIRESTORE_DATABASE_ID=
