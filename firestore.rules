rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Canonical series metadata can be read by anyone, and written/updated by authenticated users
    match /canonicalSeries/{seriesId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User progress and notifications are fully secured and restricted to the respective authenticated owner
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
